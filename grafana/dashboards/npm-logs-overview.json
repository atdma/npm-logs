        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value #A" }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(25, sum by (path) (count_over_time({job=\"npm\",log_type=\"access\",parse_state=\"parsed\",proxy_name=~\"$proxy_name\"} |= `$client_ip` |= `$user_agent` | json path, status_class, scheme | status_class=~`$status_class` | scheme=~`$scheme` [$__range])))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Requested Paths",
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value #A", "desc": true }] }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "log_type": true, "parse_state": true, "proxy_name": true, "proxy_host_id": true, "status_class": true, "scheme": true },
            "indexByName": {},
            "renameByName": { "path": "Path", "Value #A": "Requests" }
          }
        }
