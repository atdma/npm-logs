          "legendFormat": "{{proxy_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Vhost",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Only 4xx and 5xx errors, broken down by vhost and status class.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (proxy_name, status_class) (count_over_time({job=\"npm\",log_type=\"access\",parse_state=\"parsed\",proxy_name=~\"$proxy_name\"} |= `$client_ip` |= `$user_agent` | json status_class, scheme | status_class=~`$status_class` | scheme=~`$scheme` | status_class=~`4xx|5xx` [$__interval]))",
          "legendFormat": "{{proxy_name}} {{status_class}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "4xx/5xx Error Rate by Vhost",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Response body size percentiles across all selected vhosts.",
      "fieldConfig": {
        "defaults": { "unit": "decbytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.50, {job=\"npm\",log_type=\"access\",parse_state=\"parsed\",proxy_name=~\"$proxy_name\"} |= `$client_ip` |= `$user_agent` | json bytes_sent, status_class, scheme | status_class=~`$status_class` | scheme=~`$scheme` | unwrap bytes_sent | __error__=\"\" [$__interval]) by (proxy_name)",
          "legendFormat": "{{proxy_name}} p50",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {job=\"npm\",log_type=\"access\",parse_state=\"parsed\",proxy_name=~\"$proxy_name\"} |= `$client_ip` |= `$user_agent` | json bytes_sent, status_class, scheme | status_class=~`$status_class` | scheme=~`$scheme` | unwrap bytes_sent | __error__=\"\" [$__interval]) by (proxy_name)",
          "legendFormat": "{{proxy_name}} p95",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.99, {job=\"npm\",log_type=\"access\",parse_state=\"parsed\",proxy_name=~\"$proxy_name\"} |= `$client_ip` |= `$user_agent` | json bytes_sent, status_class, scheme | status_class=~`$status_class` | scheme=~`$scheme` | unwrap bytes_sent | __error__=\"\" [$__interval]) by (proxy_name)",
          "legendFormat": "{{proxy_name}} p99",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Response Size Percentiles",
      "type": "timeseries"
    },
