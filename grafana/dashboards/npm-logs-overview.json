    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Top 25 most-requested URL paths over the selected time range.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "path" }, "properties": [{ "id": "displayName", "value": "Path" }] },
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "Requests" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 6,
